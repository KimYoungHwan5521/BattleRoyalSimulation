    m_Localized: "Ung\xFCltige Vorhersage"
    m_Metadata:
      m_Items: []
  - m_Id: 2219314939228160
    m_Localized: "Mindesteinsatz betr\xE4gt 100 $."
    m_Metadata:
      m_Items: []
  - m_Id: 2219315786477568
    m_Localized: "Wette best\xE4tigen?"
    m_Metadata:
      m_Items: []
  - m_Id: 2219317690691584
    m_Localized: "Wette \xFCberspringen?"
    m_Metadata:
      m_Items: []
  - m_Id: 2219320089833472
    m_Localized: Es gibt leere Vorhersagefelder.
    m_Metadata:
      m_Items: []
  - m_Id: 2219323407527936
    m_Localized: Eine Person wurde mehrfach platziert.
    m_Metadata:
      m_Items: []
  - m_Id: 2220598824071168
    m_Localized: "F\xFCr heute im Battle Royale eingeteilter \xDCberlebender: {param0}"
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 2220595640594432
    m_Localized: Tag beenden?{param0}
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 2220597318316032
    m_Localized: "Es gibt \xDCberlebende, denen keine Ausbildung zugewiesen wird.:"
    m_Metadata:
      m_Items: []
  - m_Id: 2220600589873152
    m_Localized: "Heute ist Battle-Royale-Tag. \xDCberspringen?"
    m_Metadata:
      m_Items: []
  - m_Id: 2220602338897920
    m_Localized: Ein Tag ist vergangen.
    m_Metadata:
      m_Items: []
  - m_Id: 2224273214730240
    m_Localized: Fernkampfwaffe
    m_Metadata:
      m_Items: []
  - m_Id: 2478171783491584
    m_Localized: "Sammelbare Gegenst\xE4nde:"
    m_Metadata:
      m_Items: []
  - m_Id: 2478173167611904
    m_Localized: "W\xE4hle einen \xDCberlebenden f\xFCr das Battle Royale."
    m_Metadata:
      m_Items: []
  - m_Id: 2478174157467648
    m_Localized: "Reservierungen sind bis Freitag m\xF6glich, Stornierungen am selben
      Tag nicht erlaubt."
    m_Metadata:
      m_Items: []
  - m_Id: 2478175491256320
    m_Localized: Reservieren
    m_Metadata:
      m_Items: []
  - m_Id: 2478176929902592
    m_Localized: Reservierung stornieren
    m_Metadata:
      m_Items: []
  - m_Id: 2479575478628352
    m_Localized: Am Battle Royale teilnehmen?
    m_Metadata:
      m_Items: []
  - m_Id: 2479576816611328
    m_Localized: "F\xFCr die Meisterschaft kann nicht reserviert werden. Ein Sieg
      in der Goldliga f\xFChrt automatisch zur Reservierung der Saisonmeisterschaft,
      und ein Sieg dort zur Weltmeisterschaft."
    m_Metadata:
      m_Items: []
  - m_Id: 2479578074902528
    m_Localized: "W\xE4hle einen zu reservierenden \xDCberlebenden."
    m_Metadata:
      m_Items: []
  - m_Id: 2479579412885504
    m_Localized: "reservierter \xDCberlebender : {param0}"
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 2479581325488128
    m_Localized: "Kein qualifizierter \xDCberlebender"
    m_Metadata:
      m_Items: []
  - m_Id: 2481288361078784
    m_Localized: "{param0} ist f\xFCr ein anderes Match registriert."
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 2481303221497856
    m_Localized: '{param0} ist verletzt. Trotzdem reservieren?'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 2481289275437056
    m_Localized: "Dieser \xDCberlebende ist f\xFCr eine Meisterschaft reserviert.
      Trotzdem reservieren?"
    m_Metadata:
      m_Items: []
  - m_Id: 2481290374344704
    m_Localized: Battle Royale reserviert.
    m_Metadata:
      m_Items: []
