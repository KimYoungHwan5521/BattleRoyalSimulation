  - m_Id: 116043574400315392
    m_Localized: "Reparaturbedingung f\xFCr Helm/Weste"
    m_Metadata:
      m_Items: []
  - m_Id: 116043575365005312
    m_Localized: Repariert Helm/Weste, wenn die Haltbarkeit unter (x) % liegt.
    m_Metadata:
      m_Items: []
  - m_Id: 116043576535216128
    m_Localized: "Standardm\xE4\xDFig wird die R\xFCstung mit der h\xF6chsten Haltbarkeit
      unter der h\xF6chsten Stufe ausger\xFCstet."
    m_Metadata:
      m_Items: []
  - m_Id: 118118340732973056
    m_Localized: Freigeschaltet nach der ersten Battle-Royale-Teilnahme
    m_Metadata:
      m_Items: []
  - m_Id: 118118342322614272
    m_Localized: Wird beim Erreichen des Silber-Tiers freigeschaltet
    m_Metadata:
      m_Items: []
  - m_Id: 118118343929032704
    m_Localized: Wird beim Erreichen des Gold-Tiers freigeschaltet
    m_Metadata:
      m_Items: []
  - m_Id: 118118345401233408
    m_Localized: "Wird bei der Qualifikation f\xFCr die Saisonmeisterschaft freigeschaltet"
    m_Metadata:
      m_Items: []
  - m_Id: 118118346722439168
    m_Localized: "Wird bei der Qualifikation f\xFCr die Weltmeisterschaft freigeschaltet"
    m_Metadata:
      m_Items: []
  - m_Id: 118118348089782272
    m_Localized: Freigeschaltet durch den Sieg der Weltmeisterschaft
    m_Metadata:
      m_Items: []
  - m_Id: 118901894194720768
    m_Localized: "\rPriorit\xE4t 2"
    m_Metadata:
      m_Items: []
  - m_Id: 119618841412694016
    m_Localized: "Andere \xDCberlebende"
    m_Metadata:
      m_Items: []
  - m_Id: 121765247879540736
    m_Localized: Eigenschaft
    m_Metadata:
      m_Items: []
  - m_Id: 122098417921486848
    m_Localized: Standard
    m_Metadata:
      m_Items: []
  - m_Id: 122098419716648960
    m_Localized: Seltenheit
    m_Metadata:
      m_Items: []
  - m_Id: 122215989157359616
    m_Localized: "Die effektive Reichweite der meisten Fernkampfwaffen betr\xE4gt
      die H\xE4lfte ihrer maximalen Reichweite, und der Schaden nimmt au\xDFerhalb
      der effektiven Reichweite ab."
    m_Metadata:
      m_Items: []
  - m_Id: 123596001831874560
    m_Localized: "N\xE4chstes Sperrgebiet angek\xFCndigt:"
    m_Metadata:
      m_Items: []
  - m_Id: 123947613687443456
    m_Localized: "Klicke auf den Trainingsraum und weise \xDCberlebende dem Training
      zu."
    m_Metadata:
      m_Items: []
  - m_Id: 123961875516420096
    m_Localized: "Diese Strategie auf alle anderen \xDCberlebenden anwenden"
    m_Metadata:
      m_Items: []
  - m_Id: 123961881061289984
    m_Localized: "Alle Strategien dieses \xDCberlebenden auf alle anderen \xDCberlebenden
      anwenden"
    m_Metadata:
      m_Items: []
  - m_Id: 123965431116001280
    m_Localized: "Strategie eingef\xFCgt und gespeichert."
    m_Metadata:
      m_Items: []
  - m_Id: 125717084672421888
    m_Localized: Statistiken
    m_Metadata:
      m_Items: []
  - m_Id: 125727723826507776
    m_Localized: 'Meiste Kills in einem einzelnen Match : {0}'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 126924404182020096
