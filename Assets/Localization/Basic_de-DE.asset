    m_Localized: Strategie speichern
    m_Metadata:
      m_Items: []
  - m_Id: 1515900643110912
    m_Localized: 'Der UND-Operator wird vor dem ODER-Operator ausgewertet. Beispiel:
      A <#FF6A89>OR</color> B <#FF6A89>AND</color> C <#FF6A89>OR</color> D = A <#FF6A89>OR</color>
      (B <#FF6A89>AND</color> C) <#FF6A89>OR</color> D'
    m_Metadata:
      m_Items: []
  - m_Id: 1515902283083776
    m_Localized: "Wenn ein Gegenstand eine Herstellungspriorit\xE4t hat, werden seine
      Materialien erst beim Herstellen verbraucht."
    m_Metadata:
      m_Items: []
