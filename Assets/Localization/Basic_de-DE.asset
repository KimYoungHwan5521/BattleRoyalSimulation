  - m_Id: 115945406211878912
    m_Localized: Haltbarkeit ({param0})%\nVerteidigungsrate ({param1})%\n<size=12>Verteidigungsrate
      = Haltbarkeit + 30</size>
    m_Metadata:
      m_Items:
