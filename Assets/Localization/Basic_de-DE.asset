      m_Items: []
  - m_Id: 7594071343820800
    m_Localized: "Geplante Trainings pro \xDCberlebendem anzeigen"
    m_Metadata:
      m_Items: []
  - m_Id: 7594255456989184
    m_Localized: "\xDCberlebende mit beiden H\xE4nden oder Augen verletzt k\xF6nnen
      nicht f\xFCr K\xE4mpfe angemeldet werden."
    m_Metadata:
      m_Items: []
  - m_Id: 7594256941772800
    m_Localized: Je schwerer die Verletzung, desto langsamer die Heilung. Leichte
      Verletzungen heilen schneller.
