  - m_Id: 14169095227895808
    m_Localized: Battle Royale verlassen
    m_Metadata:
      m_Items: []
  - m_Id: 14169112638451712
    m_Localized: "M\xF6chten Sie den Battle Royale wirklich verlassen?"
    m_Metadata:
      m_Items: []
  - m_Id: 14437166169518080
    m_Localized: Bis zum Wochenende vorspulen?{param0}
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 14437159202779136
    m_Localized: Woche beenden
    m_Metadata:
      m_Items: []
  - m_Id: 15645991207759872
    m_Localized: Checkliste
    m_Metadata:
      m_Items: []
  - m_Id: 15645992545742848
    m_Localized: (Klicken zum Springen)
    m_Metadata:
      m_Items: []
  - m_Id: 15645994240241664
    m_Localized: "<color=green>Alle \xDCberlebenden sind dem Training zugewiesen.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 15645995171377152
    m_Localized: "<color=red>Nicht zugewiesene \xDCberlebende: {0}</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 15645996400308224
    m_Localized: <color=green>Alle Battle Royales dieser Woche sind reserviert.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 15645997130117120
    m_Localized: <color=red>Einige Battle Royales dieser Woche sind nicht reserviert.</color>
    m_Metadata:
      m_Items: []
  - m_Id: 15672719858790400
    m_Localized: "(Klicken Sie auf die gew\xFCnschte Liga, um den Battle Royale zu
      reservieren.)"
    m_Metadata:
      m_Items: []
  - m_Id: 16669567583055872
    m_Localized: "Nur \xDCberlebende mit derselben Stufe k\xF6nnen an den regul\xE4ren
      Ligen (Bronze, Silber, Gold) teilnehmen."
    m_Metadata:
      m_Items: []
  - m_Id: 16669569193668608
    m_Localized: "St\xE4rke: Beeinflusst Gesundheit, Blutmenge und Angriffskraft."
    m_Metadata:
      m_Items: []
  - m_Id: 16669570472931328
    m_Localized: "Beweglichkeit: Beeinflusst Angriffs-, Bewegungs- und Pl\xFCnderungsgeschwindigkeit."
    m_Metadata:
      m_Items: []
  - m_Id: 16669571852857344
    m_Localized: 'Nahkampf: Beeinflusst Treffgenauigkeit, Verteidigungs- und Ausweichrate
      im Nahkampf.'
    m_Metadata:
      m_Items: []
  - m_Id: 16669573392166912
    m_Localized: "Schie\xDFen: Beeinflusst die Genauigkeit bei Fernangriffen."
    m_Metadata:
      m_Items: []
  - m_Id: 16669574688206848
    m_Localized: "Wissen: Mit h\xF6herem Wissen k\xF6nnen mehr Gegenst\xE4nde im
      Kampf hergestellt werden. (Siehe Handbuch)"
    m_Metadata:
      m_Items: []
  - m_Id: 17095594465619968
    m_Localized: "Klicken Sie auf ein Training, um einen \xDCberlebenden zuzuweisen."
    m_Metadata:
      m_Items: []
  - m_Id: 17095599989518336
    m_Localized: "Klicken Sie auf einen \xDCberlebenden, um ihn einem Training zuzuweisen."
    m_Metadata:
      m_Items: []
  - m_Id: 17095620239618048
    m_Localized: Klicken Sie im Zeitplan auf die heutige Liga, um zum Battle Royale
      zu gelangen.
    m_Metadata:
      m_Items: []
  - m_Id: 20246174931415040
    m_Localized: 'Rang: Top 25 % = 50 % Belohnung, Top 50 % = 25 % Belohnung.'
    m_Metadata:
      m_Items: []
  - m_Id: 20355684815663104
    m_Localized: 'Gesamtbilanz: {0} Siege, {1} Rangverteidigungen, {2} Niederlagen'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20355686745042944
    m_Localized: 'Siegquote: {0}% (Siege + Rangverteidigung: {1}%)'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20355688380821504
    m_Localized: 'Goldliga+ Bilanz: {0} Siege, {1} Rangverteidigungen, {2} Niederlagen'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20355690075320320
    m_Localized: 'Gesamte Kills: {0}'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20355691618824192
    m_Localized: "Gesamt\xFCberlebenszeit: {0}"
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20355710430277632
    m_Localized: "Gesamtpr\xE4mie: <color=green>{0}$</color> (Rang {1}$ + Kills {2}$)"
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20356972957724672
    m_Localized: 'Gesamte Heilkosten: <color=red>{0}$</color> (Erste Hilfe + Transfusion
      {1}$ + OP {2}$)'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20356975931486208
    m_Localized: 'Gesamtverursachter Schaden: {0}'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20356978624229376
    m_Localized: 'Gesamt erhaltener Schaden: {0}'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 20985916245471232
    m_Localized: 'Theoretische Maximalquote: 6.375.600-fach.'
    m_Metadata:
      m_Items: []
  - m_Id: 21070832937267200
    m_Localized: Mitwirkende
    m_Metadata:
      m_Items: []
  - m_Id: 21371860463185920
    m_Localized: "Bedingung l\xF6schen"
    m_Metadata:
      m_Items: []
  - m_Id: 24796881168691200
    m_Localized: Im Kampf gesteigerte Werte
    m_Metadata:
      m_Items: []
  - m_Id: 24796884821929984
    m_Localized: Herstellung
    m_Metadata:
      m_Items: []
  - m_Id: 24796887023939584
    m_Localized: "Herstellung: Beeinflusst Herstellungsgeschwindigkeit und Herstellungsqualit\xE4t."
    m_Metadata:
      m_Items: []
  - m_Id: 24801603418124288
    m_Localized: '{2} {1} {0}'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 25083154626310144
    m_Localized: "Wenn die Verletzung nicht vollst\xE4ndig verloren ist, heilt sie
      von selbst."
    m_Metadata:
      m_Items: []
  - m_Id: 26557387210551296
    m_Localized: "Heilt in einem Tag Verletzungen, die sich von selbst erholen k\xF6nnen."
    m_Metadata:
      m_Items: []
  - m_Id: 26901118354780160
    m_Localized: "Sie k\xF6nnen einem \xDCberlebenden durch Links-/Rechtsklick ein
      Training zuweisen."
    m_Metadata:
      m_Items: []
  - m_Id: 27582987333332992
    m_Localized: Strategie wurde gespeichert.
    m_Metadata:
      m_Items: []
  - m_Id: 27583027690926080
    m_Localized: "<!> W\xE4hrend des Debuggens wurde ein Fehler erkannt. Es wird
      empfohlen, die Daten in einem anderen Slot zu speichern und neu zu starten."
    m_Metadata:
      m_Items: []
  - m_Id: 28005633560735744
    m_Localized: Feinde werden gesucht
    m_Metadata:
      m_Items: []
  - m_Id: 32698192723767296
    m_Localized: "Die gespeicherten Daten stimmen nicht mit der aktuellen Spielversion
      \xFCberein. Das Spiel funktioniert m\xF6glicherweise nicht richtig."
    m_Metadata:
      m_Items: []
  - m_Id: 32729102223470592
    m_Localized: "W\xE4hlen Sie den \xDCberlebenden aus, der am Battle Royale teilnehmen
      soll."
    m_Metadata:
      m_Items: []
  - m_Id: 32729103691476992
    m_Localized: "W\xE4hlen"
    m_Metadata:
      m_Items: []
  - m_Id: 32729105042042880
    m_Localized: Nicht teilnehmen
    m_Metadata:
      m_Items: []
  - m_Id: 32729107017560064
    m_Localized: "Best\xE4tigen? (Einmal ausgew\xE4hlt, kann es nicht ge\xE4ndert
      werden.)"
    m_Metadata:
      m_Items: []
  - m_Id: 33723748986712064
    m_Localized: Durch die Operation wurde die Charakteristik {param0} entfernt.
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 39466490228436992
    m_Localized: "Zuf\xE4llig"
    m_Metadata:
      m_Items: []
  - m_Id: 39507876633964544
    m_Localized: 1.000 $ wurden ausgezahlt. (Wird jeden Montag ausgezahlt.)
    m_Metadata:
      m_Items: []
  - m_Id: 40968955578871808
    m_Localized: Werte
    m_Metadata:
      m_Items: []
  - m_Id: 40968966148517888
    m_Localized: Verletzung
    m_Metadata:
      m_Items: []
  - m_Id: 41018071012929536
    m_Localized: "Kamerabewegung: Maus ziehen, \u201EWASD\u201C oder Pfeiltasten\nKamerazoom:
      Mausrad\nAuswahl: Klicken\nSpielgeschwindigkeit: Zifferntasten 1\u20133\nPause/Fortsetzen:
      Leertaste"
    m_Metadata:
      m_Items: []
  - m_Id: 41024498473431040
    m_Localized: "{param0} ist verletzt. M\xF6chten Sie trotzdem teilnehmen?"
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 41024727797002240
    m_Localized: 'Er kann nicht am Battle Royale teilnehmen.\n(<color=red><i>Ursache:
      {param0}</i></color>)'
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 41065281599631360
    m_Localized: "Ung\xFCltige Bedingung"
    m_Metadata:
      m_Items: []
  - m_Id: 113130481299025920
    m_Localized: "{param0} hat ein Ticket f\xFCr die Saisonmeisterschaft erhalten."
    m_Metadata:
      m_Items:
      - rid: 7835753295874359338
  - m_Id: 113130486810341376
    m_Localized: "{param0} hat ein Ticket f\xFCr die Weltmeisterschaft erhalten."
    m_Metadata:
      m_Items:
