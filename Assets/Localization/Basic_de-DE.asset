      m_Items: []
  - m_Id: 1881728492302336
    m_Localized: beide Augenverletzungen
    m_Metadata:
      m_Items: []
  - m_Id: 2205515783925760
    m_Localized: Greift an.
    m_Metadata:
      m_Items: []
  - m_Id: 2205518430531584
    m_Localized: Ignoriert.
    m_Metadata:
      m_Items: []
  - m_Id: 2205521488179200
    m_Localized: "L\xE4uft weg."
    m_Metadata:
      m_Items: []
  - m_Id: 2205524055093248
    m_Localized: "N\xE4hert sich."
    m_Metadata:
      m_Items: []
  - m_Id: 2206103192006656
    m_Localized: "Geht zur Ger\xE4uschquelle."
    m_Metadata:
      m_Items: []
  - m_Id: 2206104244776960
    m_Localized: "Blickt in Richtung des Ger\xE4uschs."
    m_Metadata:
      m_Items: []
  - m_Id: 2206105071054848
    m_Localized: "Ignoriert das Ger\xE4usch."
    m_Metadata:
      m_Items: []
  - m_Id: 2206541953953792
    m_Localized: Als erstes gesehene Person
    m_Metadata:
      m_Items: []
  - m_Id: 2206543556177920
    m_Localized: "N\xE4chste Person"
    m_Metadata:
      m_Items: []
  - m_Id: 2206544390844416
    m_Localized: "Person mit der gr\xF6\xDFten Reichweite"
    m_Metadata:
      m_Items: []
  - m_Id: 2207011464343552
    m_Localized: Keine
    m_Metadata:
      m_Items: []
  - m_Id: 2207012504530944
    m_Localized: "Strategieraum schlie\xDFen?\n(Nicht gespeicherte Daten gehen verloren.)"
    m_Metadata:
      m_Items: []
  - m_Id: 2207013309837312
    m_Localized: "Alle \xC4nderungen speichern?"
    m_Metadata:
      m_Items: []
  - m_Id: 2207014039646208
    m_Localized: "Herstellungspriorit\xE4t 1 ist deaktiviert. Bitte \xFCberpr\xFCfen
      Sie die Einstellung \"Herstellung erlauben\"."
    m_Metadata:
      m_Items: []
  - m_Id: 2217236376383488
    m_Localized: Meine Waffe
    m_Metadata:
      m_Items: []
  - m_Id: 2217237827612672
